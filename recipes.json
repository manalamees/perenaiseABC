  {"id":"k1","nameEn":"Lemon Chicken","name":"Kanafilee ahjus sidruniga","cat":"Kana","thumb":"https://www.themealdb.com/images/media/meals/xvrrux1511783685.jpg","ingredients":[{"i":"Kanafilee","m":"4 tk"},{"i":"Sidrun","m":"2 tk"},{"i":"Küüslauk","m":"4 küünt"},{"i":"Oliiviõli","m":"3 sl"},{"i":"Rosmariin","m":"2 oksa"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Kuumuta ahi 200°C.","Sega sidrunimahl, küüslauk, oliiviõli, rosmariin.","Marineeri kana 30 min.","Küpseta ahjus 25-30 min kuni kuldpruun."]},
