  {"id":"pi6","nameEn":"Tuna Pizza","name":"Tuunikala pitsa","cat":"Pitsa","thumb":"https://www.themealdb.com/images/media/meals/x0lk931587671540.jpg","ingredients":[{"i":"Pitsa tainas","m":"1 tk"},{"i":"Tomatikaste","m":"4 sl"},{"i":"Mozzarella","m":"150g"},{"i":"Tuunikalakonserv","m":"1 purk"},{"i":"Kapparid","m":"2 sl"},{"i":"Punane sibul","m":"0.5 tk"},{"i":"Oregano","m":"1 tl"}],"steps":["Kuumuta ahi 250°C.","Rulli tainas, määri kaste.","Lisa juust.","Jaota tuunikala, kapparid ja sibul peale.","Puista oregano.","Küpseta 12 min."]},
  {"id":"s1","nameEn":"Tomato Soup","name":"Tomatosupp","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Tomatid","m":"800g"},{"i":"Sibul","m":"1 tk"},{"i":"Küüslauk","m":"3 küünt"},{"i":"Köögiviljapuljong","m":"500ml"},{"i":"Koor","m":"100ml"},{"i":"Basiilik","m":"peotäis"},{"i":"Oliiviõli","m":"2 sl"},{"i":"Suhkur","m":"1 tl"}],"steps":["Prae sibul ja küüslauk oliiviõlis.","Lisa tükeldatud tomatid.","Vala puljong, hauta 20 min.","Blenderda sujuvaks.","Lisa koor ja basiilik.","Maitsesta soola, suhkru ja pipraga."]},
  {"id":"s2","nameEn":"Chicken Soup","name":"Kanasupp vermišelliga","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/syqypv1468558711.jpg","ingredients":[{"i":"Kana rinnatükk","m":"400g"},{"i":"Vermišell","m":"100g"},{"i":"Porgand","m":"2 tk"},{"i":"Seller","m":"2 vart"},{"i":"Sibul","m":"1 tk"},{"i":"Kanapuljong","m":"1.5l"},{"i":"Petersell","m":"peotäis"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Keeda kana puljongis 20 min.","Võta kana välja, lõika tükkideks.","Lisa porgand, seller, sibul puljongisse.","Keeda 10 min.","Lisa vermišell ja kana.","Keeda 5 min, maitsesta ja serveeri peterselliga."]},
  {"id":"s3","nameEn":"Pea Soup","name":"Hernesupp sealihaga","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Kuivatatud herned","m":"300g"},{"i":"Suitsutatud seajalg","m":"400g"},{"i":"Sibul","m":"1 tk"},{"i":"Porgand","m":"2 tk"},{"i":"Kartul","m":"3 tk"},{"i":"Loorberileht","m":"2 tk"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Leota herneid üleöö.","Keeda seajalg pehemeks ~1.5 tundi.","Võta liha välja, rebi tükkideks.","Lisa herned puljongisse, keeda 40 min.","Lisa porgand, kartul, sibul.","Keeda veel 20 min, lisa liha tagasi.","Maitsesta ja serveeri."]},
  {"id":"s4","nameEn":"Mushroom Soup","name":"Seenesupp koorega","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Šampinjonid","m":"500g"},{"i":"Sibul","m":"1 tk"},{"i":"Küüslauk","m":"2 küünt"},{"i":"Koor","m":"200ml"},{"i":"Köögiviljapuljong","m":"500ml"},{"i":"Või","m":"30g"},{"i":"Tüümian","m":"1 tl"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Prae sibul ja küüslauk võis.","Lisa viilutatud seened, prae kuldpruuniks.","Vala puljong, hauta 15 min.","Blenderda pool suppi sujuvaks.","Lisa koor ja tüümian.","Maitsesta ja serveeri."]},
  {"id":"s5","nameEn":"Lentil Soup","name":"Läätsesup","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Punased läätsed","m":"250g"},{"i":"Sibul","m":"1 tk"},{"i":"Porgand","m":"2 tk"},{"i":"Seller","m":"2 vart"},{"i":"Küüslauk","m":"3 küünt"},{"i":"Tomatid purk","m":"400g"},{"i":"Köögiviljapuljong","m":"1l"},{"i":"Kumin","m":"1 tl"},{"i":"Kurkum","m":"0.5 tl"}],"steps":["Prae sibul, porgand, seller küüslauguga.","Lisa kumin ja kurkum, prae 1 min.","Lisa läätsed, tomatid ja puljong.","Keeda 25-30 min kuni läätsed on pehmed.","Maitsesta ja serveeri."]},
  {"id":"s6","nameEn":"Borscht","name":"Borš","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Veiseliha","m":"400g"},{"i":"Peet","m":"3 tk"},{"i":"Kapsas","m":"300g"},{"i":"Kartul","m":"3 tk"},{"i":"Porgand","m":"2 tk"},{"i":"Sibul","m":"1 tk"},{"i":"Tomatipasta","m":"2 sl"},{"i":"Hapukoor","m":"serveerimiseks"}],"steps":["Keeda veiseliha puljongis 1 tund.","Prae sibul, porgand, riivitud peet õlis.","Lisa tomatipasta, prae 3 min.","Lisa peet-porgandisegu puljongisse.","Lisa kartul ja kapsas, keeda 20 min.","Maitsesta, serveeri hapukoorega."]},
  {"id":"s7","nameEn":"Potato Soup","name":"Kartulisupp","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Kartul","m":"6 tk"},{"i":"Sibul","m":"1 tk"},{"i":"Porgand","m":"2 tk"},{"i":"Koor","m":"150ml"},{"i":"Köögiviljapuljong","m":"1l"},{"i":"Peekon","m":"100g"},{"i":"Murulauk","m":"peotäis"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Prae peekon krõbedaks, kõrvale.","Prae sibul ja porgand peekonirasvaga.","Lisa kartulid ja puljong, keeda 20 min.","Blenderda pool suppi.","Lisa koor, maitsesta.","Serveeri peekoni ja murulauguga."]},
  {"id":"s8","nameEn":"Fish Soup","name":"Kalasupp","cat":"Supid","thumb":"https://www.themealdb.com/images/media/meals/soqwvv1487349345.jpg","ingredients":[{"i":"Lõhefilee","m":"400g"},{"i":"Kartul","m":"4 tk"},{"i":"Porgand","m":"2 tk"},{"i":"Sibul","m":"1 tk"},{"i":"Koor","m":"150ml"},{"i":"Kalapuljong","m":"1l"},{"i":"Till","m":"peotäis"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Keeda kartul ja porgand puljongis pehmeks.","Lisa lõhetükid, keeda 8-10 min.","Lisa koor, maitsesta.","Ära lase enam keema.","Serveeri tilli ja leivaga."]},
  {"id":"v1","nameEn":"Beef Stew","name":"Veiseliha hautis","cat":"Veiseliha","thumb":"https://www.themealdb.com/images/media/meals/uyqrrv1511615874.jpg","ingredients":[{"i":"Veiseliha","m":"700g"},{"i":"Kartul","m":"4 tk"},{"i":"Porgand","m":"3 tk"},{"i":"Sibul","m":"2 tk"},{"i":"Punane vein","m":"200ml"},{"i":"Lihapuljong","m":"300ml"},{"i":"Tomatipasta","m":"2 sl"},{"i":"Küüslauk","m":"3 küünt"},{"i":"Rosmariin","m":"2 oksa"}],"steps":["Lõika veiseliha kuubikuteks, pruunista õlis.","Lisa sibul ja küüslauk, prae 3 min.","Lisa tomatipasta, vein ja puljong.","Hauta 1 tund madalal kuumusel.","Lisa kartul ja porgand.","Hauta veel 30 min kuni kõik on pehme."]},
  {"id":"v2","nameEn":"Beef Burger","name":"Veiseliha burger","cat":"Veiseliha","thumb":"https://www.themealdb.com/images/media/meals/uyqrrv1511615874.jpg","ingredients":[{"i":"Veisehakkliha","m":"500g"},{"i":"Burgeri saiad","m":"4 tk"},{"i":"Cheddar","m":"4 viilu"},{"i":"Salat","m":"peotäis"},{"i":"Tomat","m":"1 tk"},{"i":"Sibul","m":"1 tk"},{"i":"Sinep","m":"1 sl"},{"i":"Ketšup","m":"2 sl"}],"steps":["Sega hakkliha soola ja pipraga.","Vormi 4 kotletti.","Grilli 4 min mõlemalt poolt.","Lisa juust, lase sulada.","Aseta saiale koos salatiga.","Lisa sinep ja ketšup."]},
  {"id":"v3","nameEn":"Beef Steak","name":"Veisepraad","cat":"Veiseliha","thumb":"https://www.themealdb.com/images/media/meals/uyqrrv1511615874.jpg","ingredients":[{"i":"Veisepraad","m":"2 tk (200g tk)"},{"i":"Küüslauk","m":"3 küünt"},{"i":"Rosmariin","m":"2 oksa"},{"i":"Või","m":"30g"},{"i":"Oliiviõli","m":"2 sl"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Lase praad toatemperatuurini soojeneda.","Maitsesta rohkelt soola ja pipraga.","Kuumuta pann väga kuumaks.","Prae 3-4 min mõlemalt poolt (medium).","Lisa või, küüslauk, rosmariin.","Lase 5 min puhata enne lõikamist."]},
  {"id":"v4","nameEn":"Beef Goulash","name":"Veiseliha guljašš","cat":"Veiseliha","thumb":"https://www.themealdb.com/images/media/meals/uyqrrv1511615874.jpg","ingredients":[{"i":"Veiseliha","m":"700g"},{"i":"Sibul","m":"3 tk"},{"i":"Paprika","m":"3 tk"},{"i":"Tomatipasta","m":"3 sl"},{"i":"Paprikapulber","m":"3 tl"},{"i":"Lihapuljong","m":"500ml"},{"i":"Küüslauk","m":"3 küünt"},{"i":"Köömned","m":"1 tl"}],"steps":["Lõika liha kuubikuteks.","Prae sibul kuldpruuniks.","Lisa liha, pruunista.","Lisa paprikapulber, tomatipasta, küüslauk.","Vala puljong, lisa köömned.","Hauta 1.5 tundi kuni liha on pehme.","Serveeri kartulipüreega."]},
  {"id":"hom1","nameEn":"Pancakes","name":"Pannkoogid","cat":"Hommikusöök","thumb":"https://www.themealdb.com/images/media/meals/rwuyqx1511383174.jpg","ingredients":[{"i":"Jahu","m":"200g"},{"i":"Piim","m":"400ml"},{"i":"Munad","m":"2 tk"},{"i":"Sool","m":"näpuotsaga"},{"i":"Suhkur","m":"1 sl"},{"i":"Või praadimiseks","m":"30g"}],"steps":["Sega jahu, sool ja suhkur.","Lisa munad ja pool piimast, klopi ühtlaseks.","Lisa ülejäänud piim, sega.","Lase 15 min seista.","Prae võis mõlemalt poolt kuldpruuniks.","Serveeri moosi, hapukoore või meega."]},
  {"id":"hom2","nameEn":"Omelette","name":"Omlett köögiviljadega","cat":"Hommikusöök","thumb":"https://www.themealdb.com/images/media/meals/rwuyqx1511383174.jpg","ingredients":[{"i":"Munad","m":"4 tk"},{"i":"Paprika","m":"0.5 tk"},{"i":"Sibul","m":"0.5 tk"},{"i":"Tomat","m":"1 tk"},{"i":"Juust","m":"50g"},{"i":"Võid","m":"15g"},{"i":"Sool ja pipar","m":"maitse järgi"}],"steps":["Klopi munad lahti, maitsesta.","Prae köögiviljad võis 3 min.","Lisa munasegu.","Prae madalal kuumusel kuni peaaegu tahke.","Lisa juust ühele poolele.","Voldi kokku ja serveeri."]},
  {"id":"hom3","nameEn":"French Toast","name":"Prantsuse röstsai","cat":"Hommikusöök","thumb":"https://www.themealdb.com/images/media/meals/rwuyqx1511383174.jpg","ingredients":[{"i":"Sai","m":"4 viilu"},{"i":"Munad","m":"2 tk"},{"i":"Piim","m":"50ml"},{"i":"Vanilliin","m":"0.5 tl"},{"i":"Kaneel","m":"0.5 tl"},{"i":"Suhkur","m":"1 sl"},{"i":"Võid praadimiseks","m":"20g"}],"steps":["Klopi munad, piim, vanilliin, kaneel ja suhkur lahti.","Kasta saiaviilud segus mõlemalt poolt.","Prae võis mõlemalt poolt kuldpruuniks.","Serveeri tuhksuhkru ja marjadega."]}
]
